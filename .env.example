# RoboTrader S4 — variables de entorno
# Copiar a .env y rellenar valores reales. Nunca commitear .env a git.

# ── Modo de operación ─────────────────────────────────────
MODE=paper                        # paper | live
USE_TESTNET=true                  # true en testnet, false en mainnet live
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING

# ── Binance API ───────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_secret_here
BINANCE_FUTS_BASE=https://fapi.binance.com
BINANCE_TESTNET_BASE=https://testnet.binancefuture.com

# ── Bot config ────────────────────────────────────────────
BOT_SYMBOL=BTCUSDT
BOT_TIMEFRAME=1h

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
